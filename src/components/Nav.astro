---
import type { CollectionEntry } from "astro:content";
import { fmt } from "@/utils/helpers";

interface Props {
  stars?: number | null;
  navigation: CollectionEntry<"navigation">["data"][];
}

const { stars, navigation } = Astro.props;

// Get the current path to determine active link
const currentPath = Astro.url.pathname;
---

<nav class="hidden items-center gap-6 md:flex" aria-label="Primary navigation">
  {
    navigation.map(({ label, href }) => (
      <a
        href={href}
        class:list={[
          "font-mono text-[0.8rem] leading-none tracking-[.03em] no-underline transition-colors",
          currentPath === href
            ? "text-foreground-bright"
            : "text-foreground-secondary hover:text-foreground-bright",
        ]}
      >
        {label}
      </a>
    ))
  }

  <a
    href="https://github.com/lancher-dev/lancher"
    target="_blank"
    rel="noopener noreferrer"
    title="View on GitHub"
    class="group flex items-stretch no-underline"
    aria-label={stars != null
      ? `GitHub — ${fmt(stars)} stars`
      : "GitHub repository"}
  >
    <span
      class="text-foreground-muted border-border group-hover:border-primary-dark group-hover:text-primary-light inline-flex h-7 items-center gap-1.5 rounded-l-sm border px-2.5 font-mono text-[0.78rem] leading-none transition-colors"
    >
      <svg
        width="13"
        height="13"
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"
        class="shrink-0"
      >
        <path
          d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"
        ></path>
      </svg>
      GitHub
    </span>
    {
      stars != null && (
        <span class="text-foreground-secondary border-border group-hover:border-primary-dark group-hover:text-primary-light inline-flex h-7 items-center gap-1 rounded-r-sm border border-l-0 px-2 font-mono text-[0.75rem] leading-none transition-colors">
          <svg
            width="10"
            height="10"
            viewBox="0 0 24 24"
            fill="currentColor"
            class="text-warning shrink-0 opacity-75"
            aria-hidden="true"
          >
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
          </svg>
          {fmt(stars)}
        </span>
      )
    }
  </a>
</nav>
