---
import { Image } from "astro:assets";
import Logo from "../assets/logo.svg";
import Nav from "./Nav.astro";
import NavMobile from "./NavMobile";
import { fetchGitHubStars } from "@/utils/github-stars";
import { getCollection } from "astro:content";

// Load navigation links
const navigation = (await getCollection("navigation")).map(
  (entry) => entry.data,
);

// Get GitHub stars
const stars = await fetchGitHubStars();
---

<header
  class="bg-background/95 border-border-dark sticky top-0 z-50 w-full border-b backdrop-blur-md"
  aria-label="Site header"
>
  <div class="mx-auto max-w-200 px-4 sm:px-8">
    <div class="grid h-13 grid-cols-[1fr_auto] items-center gap-4">
      <!-- Logo -->
      <a
        href="/"
        title="Home"
        class="group flex w-fit items-center gap-2.5 no-underline"
      >
        <Image src={Logo} alt="lancher" class="h-6 w-auto" />
        <span class="sr-only">lancher — home</span>
      </a>

      <!-- Desktop nav -->
      <Nav stars={stars} navigation={navigation} />

      <!-- Mobile nav -->
      <NavMobile client:load stars={stars} navigation={navigation} />
    </div>
  </div>
</header>
