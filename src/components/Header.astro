---
import { Image } from "astro:assets";
import Logo from "../assets/logo.svg";
import Nav from "./Nav.astro";
import NavMobile from "./NavMobile";

// Fetch GitHub stars at build time — falls back to null on error
let stars: number | null = null;
try {
  const res = await fetch("https://api.github.com/repos/lancher-dev/lancher", {
    headers: { Accept: "application/vnd.github+json" },
  });
  if (res.ok) {
    const data = await res.json();
    stars = data.stargazers_count ?? null;
  }
} catch {
  // silently ignore — stars won't be shown
}

function formatStars(n: number): string {
  return n >= 1000 ? `${(n / 1000).toFixed(1)}k` : String(n);
}
---

<header
  class="bg-background/95 border-border-dark sticky top-0 z-50 w-full border-b backdrop-blur-md"
  aria-label="Site header"
>
  <div class="mx-auto max-w-200 px-4 sm:px-8">
    <div class="grid h-[52px] grid-cols-[1fr_auto] items-center gap-4">
      <!-- Logo -->
      <a
        href="/"
        title="Home"
        class="group flex w-fit items-center gap-2.5 no-underline"
      >
        <Image src={Logo} alt="lancher" class="h-6 w-auto" />
        <span class="sr-only">lancher — home</span>
      </a>

      <!-- Desktop nav -->
      <Nav stars={stars} />

      <!-- Mobile nav -->
      <NavMobile client:load stars={stars} />
    </div>
  </div>
</header>
